{
  "name": "slime-meet",
  "version": "1.0.0",
  "description": "sLime Meet — lightweight, extensible video meeting platform",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"cd client && npx vite --host\"",
    "build": "cd client && npm run build",
    "postinstall": "cd client && npm install"
  },
  "dependencies": {
    "express": "^4.21.0",
    "socket.io": "^4.7.5"
  }
}
